# ==========================================
# Heroku XMR Ultra Low Stable v8 - afdaa
# ==========================================

APP_NAME="afdaa"

# ضع هنا عنوان محفظة Monero / XMR من زر Receive فقط
# لا تضع كلمات الاسترداد أو المفتاح الخاص
XMR_WALLET="86HoPo7YGXU66KN4L7EsMzDcNTWDpbNmd455TW18ozuoSe1JeW2pzUSUabLPEcCwG58E3jPHYLnQYB3F5ouZ7n1J4TaknW4"

# Pool الافتراضي
XMR_POOL="pool.supportxmr.com:3333"
WORKER_NAME="afdaa1"

# إعدادات الثبات القصوى على Heroku
# مهم: هذه النسخة تجبر التعدين على thread واحد فقط
XMR_THREADS="1"
RANDOMX_MODE="light"
DONATE_LEVEL="1"

# منع تشغيل worker.2 و worker.3 للتعدين إذا نسيت عدد العمال > 1
ONLY_WORKER_1="true"

# تقليل الاستهلاك بطريقة micro-throttle
# يعمل 0.20 ثانية ثم يتوقف 2.00 ثانية تقريبًا = استهلاك قليل جدًا
THROTTLE_ENABLED="true"
THROTTLE_WORK_SECONDS="0.20"
THROTTLE_SLEEP_SECONDS="2.00"

# عند قتل XMRig بالكود -9 أو 137 يتم تخفيفه أكثر تلقائيًا
AUTO_BACKOFF="true"
BACKOFF_WORK_SECONDS="0.10"
BACKOFF_SLEEP_SECONDS="5.00"

# إذا تكرر القتل كثيرًا، لا يجعل Heroku ينهار؛ ينتظر ثم يعيد المحاولة
MAX_KILLS_BEFORE_LONG_SLEEP="3"
LONG_SLEEP_SECONDS="600"
